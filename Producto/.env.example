# ═══════════════════════════════════════════════════════════════════════
# Input Medical - Variables de entorno
# Copia este archivo como .env en la raíz del proyecto
# ═══════════════════════════════════════════════════════════════════════

# ─── Base de Datos ────────────────────────────────────────────────────
# Para usar tu BD existente: cambia estos valores
DB_HOST=db
DB_PORT=5432
DB_NAME=inputmedical
DB_USER=postgres
DB_PASSWORD=postgres

# ─── Seguridad JWT ────────────────────────────────────────────────────
# IMPORTANTE: cambia esto antes de subir a producción
JWT_SECRET=cambia_esto_por_un_secreto_seguro_minimo_32_chars
