# =============================================================================
# Input Medical - .gitignore
# =============================================================================

# ─── Variables de entorno (NUNCA subir al repo) ───────────────────────────────
.env
.env.local
.env.*.local
apps/backend/.env
apps/frontend/.env

# ─── Dependencias Node.js ────────────────────────────────────────────────────
node_modules/
apps/backend/node_modules/
apps/frontend/node_modules/

# ─── Build del frontend ───────────────────────────────────────────────────────
apps/frontend/dist/
apps/frontend/.vite/
apps/frontend/build/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ─── Docker (datos locales) ───────────────────────────────────────────────────
.docker/

# ─── Editores y OS ────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
.vscode/settings.json
.idea/
*.swp
*.swo

# ─── Archivos de test y coverage ─────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Archivos temporales ─────────────────────────────────────────────────────
*.tmp
*.temp
