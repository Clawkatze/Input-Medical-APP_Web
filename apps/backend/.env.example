# ─── Servidor ────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Base de datos PostgreSQL ─────────────────────────────
# Cambia estos valores por los de tu BD existente cuando estés listo
DB_HOST=db
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_seguro_minimo_32_chars
JWT_EXPIRES_IN=8h

# ─── Supabase (opcional - para usar el cliente JS en vez de pg directo) ───
# Descomenta cuando conectes tu proyecto Supabase real
# SUPABASE_URL=https://tu-proyecto.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# ─── CORS ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
