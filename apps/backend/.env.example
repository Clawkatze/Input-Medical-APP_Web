# ─── Servidor ────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Base de datos PostgreSQL ─────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=inputmedical
DB_USER=postgres
DB_PASSWORD=postgres

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_seguro_minimo_32_chars
JWT_EXPIRES_IN=8h

# ─── Super Admin inicial ──────────────────────────────────
# Se crea automáticamente al arrancar si no hay usuarios en la BD
# Cambia la contraseña después del primer ingreso
SUPERADMIN_EMAIL=admin@inputmedical.cl
SUPERADMIN_PASSWORD=admin123
SUPERADMIN_NOMBRE=Administrador

# ─── CORS ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
